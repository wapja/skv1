APP_NAME=skv1
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://skv1.test
APP_APEX_DOMAIN=skv1.test
APP_ADMIN_HOST=admin.skv1.test

APP_LOCALE=nl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=nl_NL

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — PostgreSQL via Herd Pro (no MySQL/SQLite/MariaDB fallback per spec §1)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=skv1
DB_USERNAME=postgres
DB_PASSWORD=

# Sessions — cookie per host so demo1/demo2 don't share auth
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue — database driver per spec §1 (Horizon explicitly out of scope)
QUEUE_CONNECTION=database

CACHE_STORE=database

# Mail — Herd Pro mail service (SMTP 127.0.0.1:2525, web UI in the Herd app)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME="${APP_NAME}"
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@skv1.test"
MAIL_FROM_NAME="${APP_NAME}"

# Health check key — alternative to permission gate for monitoring agents
HEALTH_CHECK_KEY=

# Telescope is local-only (registered conditionally in AppServiceProvider)
TELESCOPE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
